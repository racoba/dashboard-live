# Hash exato que o admin digita no modal. Não use NEXT_PUBLIC_.
NEXT_ADMIN_HASH=

# Exibe o botão Admin na barra (true | 1 | yes). Qualquer outro valor oculta.
NEXT_SHOW_ADMIN=

# Fuso para “ontem” e para comparar carimbos da planilha (ex.: America/Sao_Paulo)
NEXT_RAFFLE_TIMEZONE=America/Sao_Paulo


# Planilha RAFFLE_HISTORY_URL — leitura da aba de histórico na UI /historico
# Com GID: mesmo export CSV que o sorteio (/export?format=csv&gid=). Copiar o número da URL da aba.
# NEXT_RAFFLE_HISTORY_TAB_GID=
# Sem GID: export gviz pelo nome da aba (predefinição: historico)
# NEXT_RAFFLE_HISTORY_TAB_NAME=historico
